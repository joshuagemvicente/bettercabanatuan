# Local Government Website Configuration
# Copy this file to .env.local and update with your government's information

# Government Information
VITE_GOVERNMENT_NAME="Cabanatuan City"
VITE_GOVERNMENT_TYPE="City" # or "Municipality"
VITE_REGION="Region III"
VITE_PROVINCE="Nueva Ecija"

# Website Information
VITE_WEBSITE_URL="https://www.cabanatuancity.gov.ph/"
VITE_CONTACT_EMAIL="cabanatuan.lgu@gmail.com"
VITE_CONTACT_PHONE="0919-081-3749"

# City Hall Map (OpenStreetMap coordinates)
VITE_CITY_HALL_ADDRESS="FXC2+9Q5, Corner M. De Leon Avenue and, 2nd St, Cabanatuan City, Nueva Ecija"
VITE_CITY_HALL_LAT="15.4708053"
VITE_CITY_HALL_LNG="120.9519476"
VITE_CITY_HALL_MAP_ZOOM="17"

# Social Media (Optional)
VITE_FACEBOOK_URL="https://www.facebook.com/lgucabanatuan"
VITE_TWITTER_URL="https://twitter.com/your-government"
VITE_INSTAGRAM_URL="https://instagram.com/your-government"
VITE_YOUTUBE_URL="https://youtube.com/your-government"

# SEO
VITE_SITE_DESCRIPTION="Official website of Cabanatuan City/Nueva Ecija"
VITE_SITE_KEYWORDS="government, local government, services, your city"
VITE_OG_IMAGE_URL="https://your-website.gov.ph/og-image.jpg"
VITE_TWITTER_HANDLE="@your-government"

# Analytics (Optional)
VITE_GOOGLE_ANALYTICS_ID=""
VITE_FACEBOOK_PIXEL_ID=""

# PSGC (Philippine Standard Geographic Code) API Configuration
VITE_PSGC_BASE_URL="https://classification.psa.gov/psgc"
VITE_PSGC_TOKEN="your-psgc-api-token"

VITE_PROD_ORIGIN="https://www.bettercabantuan.org"
